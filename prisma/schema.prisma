// Pocket Pizza NZ — ordering app schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_SUPABASE_URL")
}

// ───────────────────────── Catalog ─────────────────────────

// Singleton row (id="default") — editable via admin dashboard.
// Stores shop info, opening hours, delivery rules.
model StoreSettings {
  id            String   @id @default("default")
  // Shop identity
  shopName      String   @default("Pocket Pizza NZ")
  shopTagline   String   @default("Halal · Detroit-Sicilian")
  shopEmail     String   @default("pocketpizzanz@gmail.com")
  shopPhone     String?
  // Address (used as origin for delivery distance calculations)
  shopAddress   String   @default("210 New Windsor Road, New Windsor, Auckland, New Zealand")
  shopLat       Float    @default(-36.8852)
  shopLng       Float    @default(174.7177)
  // Opening hours JSON: { "fri": "5–9pm", "sat": "5–9pm", "sun": "2–6pm", ... }
  openingHours  String   @default("{\"mon\":\"Closed\",\"tue\":\"Closed\",\"wed\":\"Closed\",\"thu\":\"Closed\",\"fri\":\"5–9pm\",\"sat\":\"5–9pm\",\"sun\":\"2–6pm\"}")
  // Delivery rules
  baseFee       Float    @default(4.0)   // NZD within freeRadiusKm
  perKmAfter    Float    @default(1.5)   // NZD per km beyond freeRadiusKm
  freeRadiusKm  Float    @default(5)
  maxRadiusKm   Float    @default(30)    // hard cutoff
  estimatedMinsBase Int  @default(20)
  estimatedMinsPerKm Float @default(1.2)
  // Social
  instagramUrl  String?
  facebookUrl   String?
  // Stripe publishable key (so admin can set without redeploying)
  stripePublishableKey String?
  updatedAt     DateTime @updatedAt
}

model Category {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String?
  position    Int         @default(0)
  menuItems   MenuItem[]
}

model MenuItem {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String
  longDescription String?
  price       Float // NZD
  imageUrl    String?
  rating      String? // e.g. "G · CLASSIC"
  tags        String? // comma separated: "Vegetarian,Classic"
  isPopular   Boolean     @default(false)
  isSpicy     Boolean     @default(false)
  isHighProtein Boolean @default(false)
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  position    Int         @default(0)
  // optional extras (json stored as text in sqlite)
  extrasJson  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

// ───────────────────────── Delivery zones ─────────────────────────

model DeliveryZone {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "New Windsor"
  region      String   @default("Auckland")
  postcode    String?  // e.g. "1025"
  fee         Float    @default(0) // delivery fee NZD
  estimatedMins Int    @default(30)
  isActive    Boolean  @default(true)
  orders      Order[]
}

// ───────────────────────── Customers & Orders ─────────────────────────

model Customer {
  id          String   @id @default(cuid())
  fullName    String
  mobile      String
  email       String   @unique
  createdAt   DateTime @default(now())
  orders      Order[]
}

model Order {
  id            String   @id @default(cuid())
  reference     String   @unique // PP-XXXXXX
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])
  zoneId        String?
  zone          DeliveryZone? @relation(fields: [zoneId], references: [id])
  deliveryAddress String
  deliveryCity  String?  // e.g. "Auckland"
  deliveryRegion String? // e.g. "Auckland"
  deliveryPostcode String?
  deliveryCountry String?  @default("New Zealand")
  deliveryLat   Float?   // latitude from Google Maps geocode
  deliveryLng   Float?   // longitude from Google Maps geocode
  distanceKm    Float?   // distance from store to customer
  deliveryNotes String?
  itemsJson     String   // snapshot of items
  subtotal      Float
  deliveryFee   Float    @default(0)
  total         Float
  status        String   @default("PAID") // PAID, PREPARING, OUT_FOR_DELIVERY, DELIVERED
  paymentMethod String   @default("card") // card, stripe, windcave, poli, afterpay
  paymentLast4  String?
  paymentRef    String?  // payment intent / gateway ref
  paymentBrand  String?  // visa, mastercard, amex, etc.
  createdAt     DateTime @default(now())
  items         OrderItem[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  menuItemId  String?
  menuItem    MenuItem? @relation(fields: [menuItemId], references: [id])
  name        String
  unitPrice   Float
  quantity    Int      @default(1)
  extrasJson  String?  // chosen extras snapshot
  lineTotal   Float
}
